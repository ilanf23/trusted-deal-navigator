# Supabase — client-side (publishable, bundled into the Vite build)
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — server-side / CLI use only. NEVER commit a real value.
# Used by `npm run generate-schema` to connect to the Postgres DB directly.
DB_PASSWORD=your-db-password
